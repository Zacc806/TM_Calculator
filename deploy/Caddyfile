# Active config on the VDS (/etc/caddy/Caddyfile).
#
# Production domain — A-record calculator.atamuragroup.kz -> 93.115.14.193.
# Caddy obtains and renews a Let's Encrypt certificate automatically.
calculator.atamuragroup.kz {
	request_body {
		max_size 1MB
	}
	reverse_proxy localhost:3000
}

# Interim HTTPS via sslip.io (auto-resolves to the IP) — kept as a fallback.
93-115-14-193.sslip.io {
	request_body {
		max_size 1MB
	}
	reverse_proxy localhost:3000
}

# Plain HTTP access by IP.
http://93.115.14.193 {
	request_body {
		max_size 1MB
	}
	reverse_proxy localhost:3000
}
