# /root/tm-calculator/.env on the VDS (loaded by systemd EnvironmentFile)
PORT=3000
STATIC_ROOT=/root/tm-calculator/web
PROGRAMS_FILE=/root/tm-calculator/data/programs.json
LEADS_FILE=/root/tm-calculator/data/leads.jsonl
SITE_LEADS_FILE=/root/tm-calculator/data/site-leads.jsonl
# Comma-separated allowlist: the calculator itself + the static site whose
# lead forms POST to /api/site-lead.
ALLOWED_ORIGIN=https://calculator.atamuragroup.kz,https://atamura.group

# Leads are always saved to LEADS_FILE. The destinations below are optional mirrors.
# Telegram new-lead notification (e.g. via @BotFather token + your chat/group id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bitrix24 inbound webhook with crm scope — optional mirror to CRM.
BITRIX_WEBHOOK_URL=
BITRIX_SOURCE_ID=WEB

# Admin panel (/admin)
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
