# ── Bitrix24 lead capture (server-only, never expose to client) ──
# Inbound webhook base URL with crm scope. Portal: amanat.bitrix24.kz
# Format: https://amanat.bitrix24.kz/rest/<user_id>/<token>/
BITRIX_WEBHOOK_URL=https://amanat.bitrix24.kz/rest/<id>/<token>/

# Lead source label written to Bitrix SOURCE_ID
BITRIX_SOURCE_ID=WEB

# ── CORS ──
# Origin allowed to POST /api/lead (the calculator's own domain)
ALLOWED_ORIGIN=https://calculator.atamuragroup.kz

# ── Programs config persistence (Vercel Edge Config) ──
# Read connection string (auto-injected by Vercel when an Edge Config is linked)
EDGE_CONFIG=
# Write path: Vercel API token + Edge Config id for PATCH from /api/programs
EDGE_CONFIG_ID=
EDGE_CONFIG_WRITE_TOKEN=

# ── Admin panel auth ──
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=change-me-long-random-string

# ── Client build-time (safe to expose) ──
VITE_API_BASE=/
